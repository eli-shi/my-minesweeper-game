// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id              Int       @id @default(autoincrement())
  username        String    @unique
  email           String    @unique
  passwordHashed  String
  updated_at      DateTime  @updatedAt
  created_at      DateTime  @default(now())
  last_active_at DateTime  @default(now())
}

model Friend {
  id               Int      @id @default(autoincrement())
  following_user   User     @relation("FollowingUser", fields: [following_user_id], references: [id])
  following_user_id Int
  followed_user    User     @relation("FollowedUser", fields: [followed_user_id], references: [id])
  followed_user_id Int
  created_at       DateTime @default(now())

  @@unique([following_user_id, followed_user_id])
}

model Games {
  id           Int      @id @default(autoincrement())
  status       String
  solved_time  DateTime @db.Time
  user         User     @relation(fields: [user_id], references: [id])
  user_id      Int
  diffID       String
  created_at   DateTime @default(now())
  updated_at   DateTime @updatedAt
}

model Difficulty {
  id         Int          @id @default(autoincrement())
  diff_name  String     @unique
}

model EasyMode {
  id         Int        @id @default(autoincrement())
  user       User       @relation(fields: [user_id], references: [id])
  user_id    Int
  difficulty Difficulty @relation(fields: [diff_id], references: [id])
  diff_id    Int
  won        Int
  played     Int
  updated_at DateTime   @updatedAt
  created_at DateTime   @default(now())
}

model MediumMode {
  id         Int        @id @default(autoincrement())
  user       User       @relation(fields: [user_id], references: [id])
  user_id    Int
  difficulty Difficulty @relation(fields: [diff_id], references: [id])
  diff_id    Int
  won        Int
  played     Int
  updated_at DateTime   @updatedAt
  created_at DateTime   @default(now())
}

model HardMode {
  id         Int        @id @default(autoincrement())
  user       User       @relation(fields: [user_id], references: [id])
  user_id    Int
  difficulty Difficulty @relation(fields: [diff_id], references: [id])
  diff_id    Int
  won        Int
  played     Int
  updated_at DateTime   @updatedAt
  created_at DateTime   @default(now())
}
